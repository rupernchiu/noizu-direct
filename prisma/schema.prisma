}

// ── Chargeback Disputes ───────────────────────────────────────────────────────

model ChargebackDispute {
  id                 String    @id @default(cuid())
  airwallexDisputeId String    @unique
  orderId            String
  paymentIntentId    String
  amountUsd          Int
  currency           String    @default("USD")
  reason             String // FRAUD|DUPLICATE|PRODUCT_NOT_RECEIVED|CREDIT_NOT_PROCESSED|GENERAL
  status             String    @default("OPEN") // OPEN|UNDER_REVIEW|WON|LOST|CANCELLED
  evidenceDeadline   DateTime?
  adminNotes         String?
  outcome            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

// ── Webhook idempotency ───────────────────────────────────────────────────────
// Tracks Airwallex event IDs we've already processed, so a replayed webhook
// (same body + signature) is a no-op. Populated on every successful dispatch.
// See src/app/api/airwallex/webhook/route.ts.
model ProcessedWebhookEvent {
  id               String   @id @default(cuid())
  airwallexEventId String   @unique
  eventName        String?
  processedAt      DateTime @default(now())

  @@index([processedAt])
}

// ── Payout Setting Changes (security audit trail + 48h cooldown) ─────────────
// When a creator rotates their payout destination, the new details land here
// with `activatesAt = now + 48h`. The payout sweep reads the active encrypted
// details off CreatorProfile until `activatesAt` passes; this gives the real
// account owner a window to revoke an account-takeover attempt.
model PayoutSettingChange {
  id                   String    @id @default(cuid())
  userId               String
  previousPayoutMethod String?
  newPayoutMethod      String
  newPayoutDetails     String // AES-256 encrypted JSON (same format as CreatorProfile.payoutDetails)
  newBeneficiaryId     String?
  newPayoutCountry     String?
  newPayoutCurrency    String?
  activatesAt          DateTime
  appliedAt            DateTime?
  revokedAt            DateTime?
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime  @default(now())

  @@index([userId, activatesAt])
  @@index([appliedAt])
}

// ── Fraud Flags ───────────────────────────────────────────────────────────────

model FraudFlag {
  id          String    @id @default(cuid())
  type        String // VELOCITY|AMOUNT_THRESHOLD|CHARGEBACK_PATTERN|MANUAL
  severity    String    @default("MEDIUM") // LOW|MEDIUM|HIGH|CRITICAL
  status      String    @default("OPEN") // OPEN|REVIEWED|DISMISSED|ACTIONED
  description String
  orderId     String?
  userId      String?
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNote  String?
}

// ── Treasury / Reserves (sprint 0.7) ──────────────────────────────────────────
//
// PlatformReserve is the *ledger header* for a single reserve account
// (e.g. fraud rolling reserve, marketing accrual, per-country tax accrual).
// Movements are recorded as PlatformReserveEntry rows so we keep an audit trail
// of every accrual and release. Reserves are auto-computed daily by cron, but
// every release is approved by an admin (manual-pay pattern, same as payouts).
model PlatformReserve {
  id              String   @id @default(cuid())
  kind            String // FRAUD_ROLLING|MARKETING|TAX_DESTINATION|TAX_CREATOR_WITHHOLDING|REFUND_FLOAT
  // Optional sub-key for kinds that segment by country/creator. e.g. "MY" for
  // tax destination reserves, creatorId for withholding reserves. Null for
  // platform-wide reserves like fraud rolling.
  scope           String?
  label           String // human label shown on dashboard
  // Cumulative tracking — derived from entries but cached here for fast reads
  cumulativeInUsd Int      @default(0) // total deposits over all time, USD cents
  cumulativeOutUsd Int     @default(0) // total releases over all time, USD cents
  balanceUsd      Int      @default(0) // current = in - out
  targetUsd       Int? // optional target balance for ratio displays
  policyHoldDays  Int? // null for indefinite-hold reserves (until action), else release window
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entries PlatformReserveEntry[]

  @@unique([kind, scope])
  @@index([kind, isActive])
}

model PlatformReserveEntry {
  id          String   @id @default(cuid())
  reserveId   String
  // ACCRUAL (cron-driven, deposits into reserve)
  // RELEASE (admin-approved, withdraws from reserve to platform GA)
  // ADJUSTMENT (manual correction, e.g. reconciliation)
  direction   String // ACCRUAL|RELEASE|ADJUSTMENT
  amountUsd   Int // signed: ACCRUAL > 0, RELEASE > 0 (interpretation by direction)
  reason      String
  // Optional links for audit
  refOrderId  String?
  refPayoutId String?
  refUserId   String?
  // Approval audit (only for RELEASE)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())

  reserve PlatformReserve @relation(fields: [reserveId], references: [id], onDelete: Cascade)

  @@index([reserveId, createdAt])
  @@index([direction, createdAt])
}

// ── Audit log (cross-feature) ─────────────────────────────────────────────────
//
// AdminAuditEvent captures admin-initiated state changes that have money/policy
// impact (payout approvals, reserve releases, fee config changes). Existing
// PayoutSettingChange is feature-specific; this is a unified ledger for
// dashboard reviews and quarterly compliance audits.
model AdminAuditEvent {
  id          String   @id @default(cuid())
  actorId     String // user.id of the admin who took the action
  action      String // PAYOUT_APPROVED|RESERVE_RELEASED|FEE_RATE_CHANGED|CLAWBACK_APPLIED|DISPUTE_EVIDENCE_SUBMITTED|...
  resourceType String // PAYOUT|RESERVE|SETTINGS|ORDER|USER|DISPUTE|...
  resourceId  String?
  amountUsd   Int? // signed amount for money-moving actions
  metadata    String? // JSON blob for action-specific context
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}

// ── Digital download access log (sprint 1.4) ────────────────────────────────
// Every signed-URL emission and download attempt for a digital order is logged.
// Used to (a) enforce maxDownloadsAllowed, (b) provide chargeback evidence
// (timestamp + IP) when a buyer claims "never received", (c) feed the fraud
// review queue when access patterns look suspicious (multiple IPs, geo-distance).
model DownloadAccessLog {
  id        String   @id @default(cuid())
  orderId   String
  userId    String? // null if download token used without session (signed URL fallback)
  ipAddress String?
  userAgent String?
  outcome   String // ISSUED | DOWNLOADED | DENIED_CAP | DENIED_EXPIRED | DENIED_ESCROW
  bytesServed Int? // for partial / multi-range, optional
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([outcome, createdAt])
}

// ── Newsletter ────────────────────────────────────────────────────────────────

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String    @default("footer") // footer|checkout|modal|dashboard|other
  status         String    @default("ACTIVE") // ACTIVE|UNSUBSCRIBED|BOUNCED
  locale         String?
  userAgent      String?
  ip             String?
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  confirmedAt    DateTime?

  @@index([status, subscribedAt])
  @@index([source])
}

// ── Cron Heartbeat ────────────────────────────────────────────────────────────
//
// One row per cron job. Each invocation of `withCronHeartbeat()` upserts the
// row with its run timestamp + outcome so admins can see at-a-glance whether
// each scheduled job is firing on its expected cadence. Stale lastRanAt =
// scheduler is broken or the secret rotated.
model CronHeartbeat {
  cronName       String   @id
  lastRanAt      DateTime
  lastSucceeded  Boolean
  lastDurationMs Int
  lastError      String?
  totalRuns      Int      @default(0)
  totalFailures  Int      @default(0)
  updatedAt      DateTime @updatedAt
}
