generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  password           String?
  googleId           String?   @unique
  name               String
  role               String    @default("BUYER")
  // Bumped by password change, password reset, role demotion, soft-delete, admin suspension.
  // The NextAuth jwt() callback compares this against the token's tokenVersion and
  // rejects stale tokens (invalidates all existing sessions on bump).
  tokenVersion       Int       @default(0)
  avatar             String?
  phone              String?
  warningCount       Int       @default(0)
  isFlaggedForReview Boolean   @default(false)
  payoutFrozen       Boolean   @default(false)
  payoutFrozenReason String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Creator onboarding & verification
  creatorVerificationStatus String    @default("UNVERIFIED") // UNVERIFIED|PENDING|VERIFIED|REJECTED
  creatorVerificationNote   String?
  accountStatus             String    @default("ACTIVE") // ACTIVE|RESTRICTED|SUSPENDED|CLOSED
  restrictedAt              DateTime?
  restrictionReason         String?
  closureRequestedAt        DateTime?
  agreementsLastCheckedAt   DateTime?
  agreementSkipCount        Int       @default(0)
  legalFullName             String?
  airwallexCustomerId       String?
  // ── B2B reverse-charge (sprint 2.3) ──
  // Buyer's business tax ID. If present and buyer country ≠ creator country
  // and both are EU/SEA registered, destination tax is reverse-charged
  // (platform doesn't collect; buyer self-assesses).
  businessTaxId             String?
  businessTaxCountry        String?

  creatorProfile       CreatorProfile?
  supportSubscriptions SupportSubscription[] @relation("SupportSubscriber")
  supportTransactions  SupportTransaction[]  @relation("SupporterUser")
  buyerOrders          Order[]               @relation("BuyerOrders")
  creatorOrders        Order[]               @relation("CreatorOrders")
  ticketsAsBuyer       Ticket[]              @relation("BuyerTickets")
  ticketsAsCreator     Ticket[]              @relation("CreatorTickets")
  ticketsClosed        Ticket[]              @relation("TicketClosedBy")
  ticketMessages       TicketMessage[]
  ticketReadMarkers    TicketReadMarker[]
  blocksIssued         UserBlock[]           @relation("UserBlocksIssued")
  blocksReceived       UserBlock[]           @relation("UserBlocksReceived")
  payouts              Payout[]
  invoices             Invoice[]
  media                Media[]
  posts                Post[]                @relation("PostAuthor")
  notifications        Notification[]
  broadcastNotifications BroadcastNotification[]
  raisedDisputes       Dispute[]             @relation("DisputeRaisedBy")
  resolvedDisputes     Dispute[]             @relation("DisputeResolvedBy")
  escrowTransactions   EscrowTransaction[]
  wishlistItems        WishlistItem[]
  following            CreatorFollow[]
  cartItems            CartItem[]
  creatorApplication   CreatorApplication?
  kycUploads           KycUpload[]
  creatorAgreements    CreatorAgreement[]
  reviews              ProductReview[]
  guestbookEntries     CreatorGuestbook[]

  // Commission request/quote (as buyer)
  buyerCommissionRequests CommissionRequest[] @relation("BuyerCommissionRequests")
  buyerCommissionQuotes   CommissionQuote[]   @relation("BuyerCommissionQuotes")

  // Storage plan
  storagePlan         String               @default("FREE") // FREE | CREATOR | PRO
  storagePlanRenewsAt DateTime?
  storageBonusMb      Int                  @default(0) // admin-granted extra quota
  storageOverageBytes BigInt               @default(0) // accumulated overage
  storageSubscription StorageSubscription?

  @@index([role])
  @@index([accountStatus])
  @@index([creatorVerificationStatus])
}

model CreatorProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  username               String    @unique
  displayName            String
  bio                    String?
  bannerImage            String?
  avatar                 String?
  socialLinks            String    @default("{}")
  categoryTags           String    @default("[]")
  commissionStatus       String    @default("OPEN")
  announcementText       String?
  announcementActive     Boolean   @default(false)
  featuredProductIds     String    @default("[]")
  isVerified             Boolean   @default(false)
  isTopCreator           Boolean   @default(false)
  totalSales             Int       @default(0)
  absorbProcessingFee    Boolean   @default(false)
  portfolioItems         String    @default("[]")
  isSuspended            Boolean   @default(false)
  badges                 String    @default("[]")
  commissionSlots        Int?
  commissionTerms        String?
  commissionPricing      String    @default("[]")
  commissionDescription  String?
  commissionDefaults     String    @default("{}") // JSON: { depositPercent, revisionsIncluded, turnaroundDays, milestoneTemplates: [{name, stages: [{label, percent}]}], preferMilestones }
  logoImage              String?
  popupEnabled           Boolean   @default(false)
  popupTitle             String?
  popupDescription       String?
  popupCtaText           String?
  popupCtaLink           String?
  popupBadgeText         String?
  popupImageUrl          String?
  notifPrefs             String    @default("{}")
  themeColor             String?
  sectionOrder           String    @default("[]")
  storeStatus            String    @default("ACTIVE") // ACTIVE | IDLE | HIATUS | FLAGGED
  storeStatusReason      String?
  storeStatusUpdatedAt   DateTime?
  lastLoginAt            DateTime?
  fulfillmentWarnings    Int       @default(0)
  healthEmailSentAt      String? // JSON: { nudge30, reengagement, fulfillmentWarn, preSuspension }
  onboardingCompleted    Boolean   @default(false)
  onboardingDismissed    Boolean   @default(false)
  airwallexBeneficiaryId String?
  payoutMethod           String    @default("bank_transfer")
  boostMultiplier        Float     @default(1.0)
  lastFeaturedAt         DateTime?
  payoutDetails          String? // AES-256 encrypted JSON
  payoutCountry          String?
  payoutCurrency         String?
  // ── SWIFT corridor (sprint 1.5) ──
  // Tier-3 SEA: VN/KH/MM/LA — Airwallex local payout rails not available, so
  // payouts go via SWIFT international wire. Fees (sender + intermediary +
  // beneficiary bank) are passed through to the creator at payout-method setup.
  payoutRail             String    @default("LOCAL") // LOCAL | SWIFT | PAYPAL
  swiftBankName          String?
  swiftBankCode          String? // BIC/SWIFT code
  swiftIntermediaryFeeUsd Int?    // creator-disclosed estimate (cents)
  // ── Personal tax (sprint 2.1) ──
  // Self-declared at onboarding. If true, platform marks up the buyer price by
  // taxRatePercent and withholds it from the payout, remitting on the creator's
  // behalf. If false, no tax is applied — creator self-declares own taxes.
  taxRegistered          Boolean   @default(false)
  taxId                  String? // SST/GST/VAT registration number
  taxRatePercent         Float? // overrides PlatformSettings.defaultCreatorTaxRatePercent
  taxJurisdiction        String? // ISO-3166 alpha-2; falls back to payoutCountry
  // ── Tax architecture (2026-04-27, migration 0013) ──
  // Captured at post-approval onboarding (`/dashboard/onboarding/tax`).
  // creatorClassification gates whether sales-tax opt-in is even available.
  creatorClassification         String?      // 'INDIVIDUAL' | 'REGISTERED_BUSINESS'
  taxOnboardingAcknowledgedAt   DateTime?
  taxOnboardingTosVersion       String?      // e.g. "2026-04-27"
  // Creator's own sales tax — opt-in agency-collect (Phase 7 activates).
  // Platform collects at checkout, passes through gross in payout, creator
  // remits to their own tax authority. Approval queue gates collection.
  collectsSalesTax              Boolean      @default(false)
  salesTaxRate                  Float?       // e.g. 0.06
  salesTaxLabel                 String?      // 'SST' | 'GST' | 'VAT'
  salesTaxStatus                String       @default("NONE") // NONE|REQUESTED|APPROVED|REJECTED
  salesTaxApprovedAt            DateTime?
  salesTaxApprovedBy            String?      // admin user id
  salesTaxCertificateUrl        String?      // upload of reg cert
  // ── Shipping V2 (2026-04-27): per-product rates, creator-level only keeps cart prefs ──
  // shippingByCountry is soft-deprecated — kept nullable for backfill safety; runtime
  // reads only Product.shippingByCountry. May be reused in future as a "starting-point
  // template" creators can bulk-apply when adding new listings.
  shippingByCountry      String? // JSON: { [iso2|"ROW"]: usdCents } — DEPRECATED, do not read
  shippingFreeThresholdUsd Int? // null = no free-ship threshold (creator-level, cart-wide)
  combinedShippingEnabled Boolean  @default(true) // multi-item carts: charge highest-rate item only
  createdAt              DateTime  @default(now())

  user                 User                  @relation(fields: [userId], references: [id])
  products             Product[]
  videos               Video[]
  supportTiers         SupportTier[]
  supportGoals         SupportGoal[]
  supportGift          SupportGift?
  supportTransactions  SupportTransaction[]
  supportSubscriptions SupportSubscription[]
  podProviders         CreatorPodProvider[]
  followers            CreatorFollow[]
  broadcasts           Broadcast[]
  guestbookEntries     CreatorGuestbook[]
  discountCodes        DiscountCode[]
  commissionRequests   CommissionRequest[]
  commissionQuotes     CommissionQuote[]
}

// ── POD Provider ──────────────────────────────────────────────────────────────

model CreatorPodProvider {
  id                    String   @id @default(cuid())
  creatorId             String
  name                  String // PRINTIFY|PRINTFUL|MERCHIZE|CJ_DROPSHIPPING|GOOTEN|LOCAL_PRINT_SHOP|SELF_FULFILLED|OTHER
  customName            String?
  storeUrl              String?
  notes                 String?
  isDefault             Boolean  @default(false)
  defaultProductionDays Int      @default(5)
  shippingMY            Int      @default(5)
  shippingSG            Int      @default(7)
  shippingPH            Int      @default(10)
  shippingIntl          Int      @default(14)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  creator  CreatorProfile @relation(fields: [creatorId], references: [id])
  products Product[]
}

// ── Product ───────────────────────────────────────────────────────────────────

model Product {
  id                          String    @id @default(cuid())
  creatorId                   String
  title                       String
  description                 String
  price                       Int
  category                    String
  type                        String // DIGITAL | PHYSICAL | POD | COMMISSION
  // Commission-specific
  commissionDepositPercent    Int?
  commissionRevisionsIncluded Int?
  commissionTurnaroundDays    Int?
  images                      String    @default("[]")
  digitalFile                 String?
  digitalFiles                String? // JSON array of { key, filename, size, mime }
  stock                       Int?
  isActive                    Boolean   @default(true)
  isPinned                    Boolean   @default(false)
  order                       Int       @default(0)
  // POD fields
  podProviderId               String?
  baseCost                    Int?
  productionDays              Int?
  shippingMY                  Int? // LEAD TIME (days), not cost
  shippingSG                  Int? // LEAD TIME (days), not cost
  shippingPH                  Int? // LEAD TIME (days), not cost
  shippingIntl                Int? // LEAD TIME (days), not cost
  // ── Per-product shipping rates (Shipping V2, 2026-04-27) ──
  // Sole source of truth. PHYSICAL/POD listings must have ≥1 entry to publish.
  // null/empty = no shipping configured (publish guard blocks PHYSICAL/POD).
  shippingByCountry           String? // JSON: { [iso2|"ROW"]: usdCents }
  showProviderPublic          Boolean   @default(false)
  podExternalUrl              String?
  sizeVariants                String? // JSON array of size strings
  colorVariants               String? // JSON array of {name, mockupImage}
  trendingScore               Float     @default(0)
  trendingVersion             Int       @default(1)
  trendingUpdatedAt           DateTime?
  manualBoost                 Int       @default(0)
  isTrendingSuppressed        Boolean   @default(false)
  reviewCount                 Int       @default(0)
  averageRating               Float     @default(0)
  isPreOrder                  Boolean   @default(false)
  preOrderMessage             String?
  preOrderReleaseAt           DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  creator               CreatorProfile          @relation(fields: [creatorId], references: [id])
  podProvider           CreatorPodProvider?     @relation(fields: [podProviderId], references: [id])
  orders                Order[]
  wishlistItems         WishlistItem[]
  cartItems             CartItem[]
  views                 ProductView[]
  trendingScoreRecord   ProductTrendingScore?
  sourceRecommendations ProductRecommendation[] @relation("SourceProduct")
  targetRecommendations ProductRecommendation[] @relation("TargetProduct")
  reviews               ProductReview[]
  discountCodes         DiscountCode[]
}

// ── Product View Tracking ──────────────────────────────────────────────────────

model ProductView {
  id        String   @id @default(cuid())
  productId String
  sessionId String
  userId    String?
  ipAddress String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([ipAddress, productId, createdAt])
  @@index([sessionId, productId, createdAt])
}

// ── Trending Score Shadow Table ────────────────────────────────────────────────

model ProductTrendingScore {
  id           String   @id @default(cuid())
  productId    String   @unique
  version      Int
  score        Float
  breakdown    String // JSON: { orders_7d, wishlist_7d, cart_7d, views_7d, raw, decay_applied, manualBoost, final, version }
  calculatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ── Product Recommendations ────────────────────────────────────────────────────

model ProductRecommendation {
  id                   String   @id @default(cuid())
  sourceProductId      String
  recommendedProductId String
  score                Float
  sharedBuyers         Int
  computedAt           DateTime @default(now())

  sourceProduct      Product @relation("SourceProduct", fields: [sourceProductId], references: [id], onDelete: Cascade)
  recommendedProduct Product @relation("TargetProduct", fields: [recommendedProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, recommendedProductId])
  @@index([sourceProductId, score(sort: Desc)])
}

// ── Product Reviews ────────────────────────────────────────────────────────────

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  orderId      String?  @unique
  buyerId      String
  rating       Int
  title        String?
  body         String?
  isVerified   Boolean  @default(false)
  isVisible    Boolean  @default(false)
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@unique([productId, buyerId])
  @@index([productId, createdAt])
  @@index([buyerId])
}

model CreatorGuestbook {
  id               String   @id @default(cuid())
  creatorProfileId String
  authorId         String
  content          String
  rating           Int?
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  isVisible        Boolean  @default(false)
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id])
  author         User           @relation(fields: [authorId], references: [id])

  @@index([creatorProfileId, createdAt])
  @@index([authorId])
}

// ── Order ─────────────────────────────────────────────────────────────────────

model Order {
  id                             String    @id @default(cuid())
  buyerId                        String
  creatorId                      String
  productId                      String
  status                         String    @default("PENDING")
  amountUsd                      Int
  displayCurrency                String    @default("USD")
  displayAmount                  Int       @default(0)
  exchangeRate                   Float     @default(1.0)
  exchangeRateAt                 DateTime?
  cartSessionId                  String?
  airwallexIntentId              String?
  // ── Rail-aware fee breakdown (sprint 0.1) ──
  // Snapshotted at intent-creation time so the webhook + payouts reproduce
  // the exact split even if PlatformSettings rates change later.
  paymentRail                    String? // FPX|FAST|PAYNOW|GCASH|CARD|...  (null = legacy 2.5% flat)
  subtotalUsd                    Int? // pre-fee subtotal in USD cents
  buyerFeeUsd                    Int? // buyer-side surcharge in USD cents
  creatorCommissionUsd           Int? // 5% commission deducted at payout
  buyerCountry                   String? // ISO-3166-1 alpha-2, for per-country GMV/tax meter
  // ── Tax engine snapshot (sprint 2.x) ──
  destinationTaxAmountUsd        Int       @default(0) // Layer 2: platform's destination tax
  destinationTaxRatePercent      Float? // rate at order time (snapshot)
  destinationTaxCountry          String? // tax jurisdiction (usually = buyerCountry)
  creatorTaxAmountUsd            Int       @default(0) // Layer 1: creator personal tax markup
  creatorTaxRatePercent          Float? // creator's rate at order time
  reverseChargeApplied           Boolean   @default(false) // B2B reverse-charge flag (sprint 2.3)
  buyerBusinessTaxId             String? // buyer's tax ID if B2B reverse-charge claimed
  // ── Tax architecture (2026-04-27, migration 0013) ──
  // creatorCountry: ISO-2 snapshot at order creation. Drives PPh attribution
  // even if creator later changes country in their profile. Mirrors buyerCountry.
  creatorCountry                 String?
  // Creator's own sales tax (Layer 1.5 — agency-collected, passed through gross).
  creatorSalesTaxAmountUsd       Int       @default(0)
  creatorSalesTaxRatePercent     Float?
  creatorSalesTaxLabel           String?   // 'SST' | 'GST' | 'VAT'
  // Platform fee tax — buyer side (taxes our buyer service fee in buyer's country).
  platformFeeBuyerTaxUsd         Int       @default(0)
  platformFeeBuyerTaxRate        Float?
  // Platform fee tax — creator side (taxes our commission in creator's country).
  platformFeeCreatorTaxUsd       Int       @default(0)
  platformFeeCreatorTaxRate      Float?
  // ── Shipping snapshot (sprint shipping-1) ──
  // Snapshotted at intent creation; passes through to creator (no platform fee).
  // Refunded if escrowStatus is still HELD; retained if TRACKING_ADDED+.
  // On chargeback, reversed in full (network rules).
  shippingCostUsd                Int       @default(0)
  shippingDestinationCountry     String? // ISO-3166 alpha-2 used for rate lookup
  shippingFreeApplied            Boolean   @default(false) // true if free-ship threshold waived the cost
  trackingNumber                 String?
  courierName                    String?
  courierCode                    String?
  trackingAddedAt                DateTime?
  estimatedDelivery              DateTime?
  shippingAddress                String?
  downloadToken                  String?
  downloadExpiry                 DateTime?
  downloadCount                  Int       @default(0)
  // ── Digital download fraud defenses (sprint 1.4) ──
  maxDownloadsAllowed            Int       @default(5)
  downloadCapReachedAt           DateTime?
  // ── Refund lifecycle (sprint 3.0) ──
  // Once a refund is initiated (admin or dispute resolution), refundStatus tracks
  // the Airwallex side: NONE → PENDING (request emitted) → SUCCEEDED|FAILED.
  // escrowStatus tracks the *internal* state; refundStatus tracks whether the
  // money actually left Airwallex. Both must reach a terminal state before we
  // consider the order fully closed.
  refundStatus                   String    @default("NONE") // NONE|PENDING|SUCCEEDED|FAILED
  refundRequestedAt              DateTime?
  refundProcessedAt              DateTime?
  refundFailureReason            String?
  airwallexRefundId              String?
  // Escrow
  escrowStatus                   String    @default("HELD") // HELD|TRACKING_ADDED|RELEASED|DISPUTED|REFUNDED|PARTIALLY_REFUNDED
  escrowHeldAt                   DateTime?
  escrowReleasedAt               DateTime?
  escrowAutoReleaseAt            DateTime?
  fulfillmentDeadline            DateTime?
  fulfillmentWarningsSent        Int       @default(0)
  buyerConfirmedAt               DateTime?
  discountCodeId                 String?
  discountAmount                 Int       @default(0)
  // Commission fields
  commissionStatus               String? // PENDING_ACCEPTANCE|ACCEPTED|DELIVERED|REVISION_REQUESTED|COMPLETED
  commissionBriefText            String?
  commissionReferenceImages      String? // JSON array of URLs
  commissionDepositPercent       Int? // snapshot at order time
  commissionDepositAmount        Int? // cents
  commissionRevisionsAllowed     Int? // snapshot
  commissionRevisionsUsed        Int       @default(0)
  commissionAcceptedAt           DateTime?
  commissionDeliveredAt          DateTime?
  commissionDeliveryFiles        String? // JSON array of URLs
  commissionAcceptDeadlineAt     DateTime? // 48h from order creation
  commissionBuyerAcceptedAt      DateTime?
  commissionDepositConsentAt     DateTime? // when buyer consented to deposit release at checkout
  commissionDepositAutoReleaseAt DateTime? // 48h after creator acceptance + new creator modifier
  commissionDepositReleasedAt    DateTime? // when deposit portion was actually released to creator
  // Quote-based commissions (Lane B + C)
  commissionQuoteId              String?   @unique // if this Order came from an accepted CommissionQuote
  commissionIsMilestoneBased     Boolean   @default(false)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  buyer              User                  @relation("BuyerOrders", fields: [buyerId], references: [id])
  creator            User                  @relation("CreatorOrders", fields: [creatorId], references: [id])
  product            Product               @relation(fields: [productId], references: [id])
  transactions       Transaction[]
  invoices           Invoice[]
  ticket             Ticket?
  dispute            Dispute?
  escrowTransactions EscrowTransaction[]
  review             ProductReview?
  discountCode       DiscountCode?         @relation(fields: [discountCodeId], references: [id])
  chargebacks        ChargebackDispute[]
  commissionQuote    CommissionQuote?      @relation(fields: [commissionQuoteId], references: [id])
  milestones         CommissionMilestone[]

  @@index([airwallexIntentId])
  @@index([escrowAutoReleaseAt])
  @@index([status, createdAt])
  @@index([buyerId, createdAt])
  @@index([creatorId, status])
}

// ── Dispute ───────────────────────────────────────────────────────────────────

model Dispute {
  id                 String    @id @default(cuid())
  orderId            String    @unique
  raisedBy           String
  reason             String // NEVER_ARRIVED|WRONG_ITEM|PRINT_QUALITY|WRONG_SIZE|DAMAGED|OTHER
  description        String
  evidence           String    @default("[]") // JSON array of image URLs
  creatorResponse    String?
  creatorEvidence    String? // JSON array
  creatorRespondedAt DateTime?
  status             String    @default("OPEN") // OPEN|UNDER_REVIEW|RESOLVED_REFUND|RESOLVED_RELEASE|CLOSED
  adminNote          String?
  resolvedBy         String?
  resolvedAt         DateTime?
  refundAmount       Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  order    Order @relation(fields: [orderId], references: [id])
  raiser   User  @relation("DisputeRaisedBy", fields: [raisedBy], references: [id])
  resolver User? @relation("DisputeResolvedBy", fields: [resolvedBy], references: [id])

  evidenceFiles DisputeEvidence[]
}

// ── Escrow Transaction ────────────────────────────────────────────────────────

model EscrowTransaction {
  id          String   @id @default(cuid())
  orderId     String
  milestoneId String?
  type        String // HOLD|RELEASE|REFUND|PARTIAL_REFUND|ADMIN_RELEASE|MILESTONE_RELEASE
  amount      Int
  note        String?
  performedBy String?
  createdAt   DateTime @default(now())

  order     Order                @relation(fields: [orderId], references: [id])
  performer User?                @relation(fields: [performedBy], references: [id])
  milestone CommissionMilestone? @relation(fields: [milestoneId], references: [id])
}

// ── Notification ──────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // NEW_ORDER|FULFILLMENT_REMINDER|FULFILLMENT_WARNING|FULFILLMENT_FINAL_WARNING|ORDER_CANCELLED|ESCROW_RELEASED|TICKET_OPENED|TICKET_REPLY|TICKET_CLOSED|DISPUTE_RAISED|DISPUTE_RESOLVED|PAYOUT_PROCESSED|ORDER_CONFIRMED|ORDER_SHIPPED|DOWNLOAD_READY|REFUND_ISSUED
  title     String
  message   String
  orderId   String?
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ── Transaction ───────────────────────────────────────────────────────────────

model Transaction {
  id                 String   @id @default(cuid())
  orderId            String
  buyerId            String
  creatorId          String
  grossAmountUsd     Int
  processingFee      Int
  platformFee        Int      @default(0)
  withdrawalFee      Int      @default(0)
  creatorAmount      Int
  currency           String   @default("USD")
  // ── Rail-aware fee breakdown (sprint 0.1, 5/5.5/8) ──
  paymentRail        String? // FPX|FAST|PAYNOW|GCASH|CARD|... null = legacy
  subtotalUsd        Int? // pre-fee subtotal in USD cents
  buyerFeeUsd        Int? // buyer surcharge component
  creatorCommissionUsd Int? // 5% commission piece (overlaps with platformFee semantically once new model is live)
  buyerCountry       String? // ISO-3166-1 alpha-2, for per-country GMV meter
  // ── Tax engine (sprint 2.x) ──
  destinationTaxUsd  Int      @default(0) // Layer 2 destination tax collected
  creatorTaxUsd      Int      @default(0) // Layer 1 markup-and-withhold for tax-registered creators
  reverseCharge      Boolean  @default(false)
  // ── Shipping pass-through (sprint shipping-1) ──
  // Mirrored from Order.shippingCostUsd. No platform fee on shipping; the full
  // amount is added to creatorAmount for payout.
  shippingCostUsd    Int      @default(0)
  airwallexReference String?
  status             String   @default("PENDING")
  // Chargeback/dispute: when a payment.dispute.created webhook fires *after* a
  // transaction is already COMPLETED, we flip this flag so the payout cron
  // excludes the amount from the creator's available balance until the dispute
  // resolves. Set back to false on dispute.won.
  payoutBlocked      Boolean  @default(false)
  payoutBlockReason  String?
  createdAt          DateTime @default(now())

