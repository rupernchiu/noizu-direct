// ── Tickets (replaces Conversation/Message) ──────────────────────────────────
//
// Service-ticket model. Every buyer↔creator thread is a ticket with a subject,
// kind, and close lifecycle. Only buyers open tickets; only creators close them.
// New inquiries = new tickets. Linked to the commission/order that spawned them
// (or standalone GENERAL tickets for free-form questions).
//
// Retention: hard-delete 90 days after close; pauses during active disputes.
// Auto-close: 30 days of two-sided silence (unless linked order/milestone/dispute
// is still active).
model Ticket {
  id                  String    @id @default(cuid())
  subject             String // required, <= 140 chars
  kind                String // GENERAL | QUOTE | COMMISSION | ORDER
  status              String    @default("OPEN") // OPEN | CLOSED
  buyerId             String
  creatorId           String // User.id of the creator (NOT CreatorProfile.id)
  openedById          String // User.id who fired the open event (buyer, or creator for auto-opened quote)
  openedAutoSource    String? // REQUEST | QUOTE | ORDER | null when manually opened

  // At most one link is set; determines `kind` + auto-close blockers
  commissionRequestId String?   @unique
  commissionQuoteId   String?   @unique
  orderId             String?   @unique

  // Lifecycle timestamps
  lastBuyerMessageAt   DateTime?
  lastCreatorMessageAt DateTime?
  lastMessageAt        DateTime  @default(now())
  closedAt             DateTime?
  closedById           String?
  closeReason          String? // CREATOR_CLOSED | AUTO_INACTIVITY | ADMIN
  purgeAt              DateTime? // closedAt + 90d (paused during active dispute)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  buyer    User  @relation("BuyerTickets", fields: [buyerId], references: [id])
  creator  User  @relation("CreatorTickets", fields: [creatorId], references: [id])
  closedBy User? @relation("TicketClosedBy", fields: [closedById], references: [id])

  commissionRequest CommissionRequest? @relation(fields: [commissionRequestId], references: [id])
  commissionQuote   CommissionQuote?   @relation(fields: [commissionQuoteId], references: [id])
  order             Order?             @relation(fields: [orderId], references: [id])

  messages    TicketMessage[]
  attachments TicketAttachment[]
  readMarkers TicketReadMarker[]

  @@index([buyerId, status, lastMessageAt])
  @@index([creatorId, status, lastMessageAt])
  @@index([status, lastMessageAt])
  @@index([purgeAt])
  @@index([kind, status])
}

model TicketMessage {
  id           String    @id @default(cuid())
  ticketId     String
  senderId     String
  body         String // text content, trimmed, <= 5000
  systemKind   String? // null for user msg; "OPENED" | "CLOSED" | "AUTO_CLOSED" | "REOPENED" | "BLOCKED"
  reportedAt   DateTime?
  reportedById String?
  isDeleted    Boolean   @default(false) // admin/GDPR soft-delete; row kept for thread continuity
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())

  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User               @relation(fields: [senderId], references: [id])
  attachments TicketAttachment[]

  @@index([ticketId, createdAt])
  @@index([senderId, createdAt])
  @@index([reportedAt])
}

// Append-only attachment log. Mirrors DisputeEvidence/KycUpload pattern — once
// uploaded, images are never edited; replacements mark the old row superseded.
// R2 delete only runs through the admin housekeeping cron path.
model TicketAttachment {
  id           String    @id @default(cuid())
  ticketId     String
  messageId    String? // null only if upload succeeded but message create failed
  uploaderId   String
  r2Key        String
  viewerUrl    String
  mimeType     String?
  fileSize     Int?
  supersededBy String?   @unique
  supersededAt DateTime?
  createdAt    DateTime  @default(now())

  ticket  Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message TicketMessage? @relation(fields: [messageId], references: [id])

  @@index([ticketId, createdAt])
  @@index([uploaderId])
}

// Per-user last-read cursor on a ticket. Drives unread badges without N+1 scans.
model TicketReadMarker {
  id         String   @id @default(cuid())
  ticketId   String
  userId     String
  lastReadAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([ticketId, userId])
  @@index([userId, lastReadAt])
}

// User-level blocks. Creators block buyers — buyer can't open new tickets
// against this creator, and existing tickets flip read-only.
model UserBlock {
  id        String   @id @default(cuid())
  blockerId String // creator User.id
  blockedId String // buyer User.id
  reason    String?
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocksIssued", fields: [blockerId], references: [id])
  blocked User @relation("UserBlocksReceived", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

