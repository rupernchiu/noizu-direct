  email          String    @unique
  name           String
  department     String?
  passwordHash   String
  isSuperAdmin   Boolean   @default(false)
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastLogin      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  permissions StaffUserPermission[]
  auditEvents AuditEvent[]
}

model StaffPermission {
  id          String   @id @default(cuid())
  shortcode   String   @unique // format: component.action e.g. "creators.suspend"
  displayName String
  description String?
  component   String
  action      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userGrants StaffUserPermission[]
}

model StaffUserPermission {
  id                String    @id @default(cuid())
  staffUserId       String
  staffPermissionId String
  assignedAt        DateTime  @default(now())
  assignedById      String?
  expiresAt         DateTime?

  staffUser       StaffUser       @relation(fields: [staffUserId], references: [id])
  staffPermission StaffPermission @relation(fields: [staffPermissionId], references: [id])

  @@unique([staffUserId, staffPermissionId])
}

model StaffRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  actorName   String
  action      String
  entityType  String
  entityId    String
  entityLabel String?
  reason      String?
  beforeJson  String?
  afterJson   String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor StaffUser? @relation(fields: [actorId], references: [id])
}

// ── Creator Spotlight ─────────────────────────────────────────────────────────

model CreatorSpotlight {
  id             String   @id @default(cuid())
  displayName    String
  creatorType    String
  location       String
  quote          String
  earningsStat   String
  earningsPeriod String
