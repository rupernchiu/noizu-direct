  depositPercent    Int       @default(0)
  revisionsIncluded Int       @default(1)
  turnaroundDays    Int
  termsText         String?
  isMilestoneBased  Boolean   @default(false)
  status            String    @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED | EXPIRED | WITHDRAWN
  expiresAt         DateTime // 7d from SENT
  sentAt            DateTime?
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  request    CommissionRequest?    @relation(fields: [requestId], references: [id])
  creator    CreatorProfile        @relation(fields: [creatorId], references: [id])
  buyer      User                  @relation("BuyerCommissionQuotes", fields: [buyerId], references: [id])
  milestones CommissionMilestone[]
  order      Order? // set when buyer accepts + pays
  ticket     Ticket?

  @@index([creatorId, status])
  @@index([buyerId, status])
  @@index([status, expiresAt])
}

model CommissionMilestone {
  id               String    @id @default(cuid())
  quoteId          String
  orderId          String? // populated when quote accepted → Order created
  order            Int       @default(0) // sequence
  title            String
  description      String?
  amountUsd        Int
  status           String    @default("PENDING") // PENDING | IN_PROGRESS | DELIVERED | APPROVED | REVISION_REQUESTED | COMPLETED | REFUNDED
  deliveredAt      DateTime?
  deliveryFiles    String? // JSON array of { key, filename, size, mime }
  deliveryNote     String?
  approvedAt       DateTime?
  revisionNote     String?
  autoReleaseAt    DateTime? // 14 days after delivery
  releasedAt       DateTime?
  revisionsUsed    Int       @default(0)
  revisionsAllowed Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  quote         CommissionQuote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  orderRef      Order?              @relation(fields: [orderId], references: [id])
  escrowEntries EscrowTransaction[]

  @@index([quoteId, order])
  @@index([orderId, status])
  @@index([status, autoReleaseAt])
}

// ── Creator Onboarding ────────────────────────────────────────────────────────

model AgreementTemplate {
  id            String    @id @default(cuid())
  type          String // CREATOR_TOS|IP_DECLARATION|PAYMENT_TERMS|PRIVACY_POLICY|COMMUNITY_GUIDELINES
  version       String
  title         String
  content       String
  summary       String
  changeLog     String?
  effectiveDate DateTime
  isActive      Boolean   @default(false)
  createdBy     String
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?

  agreements CreatorAgreement[]
}

model CreatorAgreement {
  id                String   @id @default(cuid())
  userId            String
  templateId        String
  agreementType     String
  agreementVersion  String
  agreedAt          DateTime @default(now())
  ipAddress         String
  userAgent         String
  signedName        String
  agreementSnapshot String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id])
  template AgreementTemplate @relation(fields: [templateId], references: [id])
}

// H6 — KYC upload binding. When /api/upload stores an identity file it also
// writes a row here keyed to the uploader's userId. /api/creator/apply then
// accepts `idFrontUploadId` / `idBackUploadId` / `selfieUploadId` opaque
// references, looks up the row server-side, and verifies `userId ===
// session.user.id` before copying the R2 key into CreatorApplication.
// Without this, any user with another user's /api/files/identity/… URL can
// submit it as their own ID.
model KycUpload {
  id           String    @id @default(cuid())
  userId       String
  category     String // id_front | id_back | selfie
  r2Key        String
  viewerUrl    String
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime  @default(now())
  // Append-only semantics. When a creator re-uploads a replacement before submit,
  // the old row is marked superseded (never deleted). Admin housekeeping is the
  // only code path allowed to delete from R2 + remove rows.
  supersededBy String?   @unique
  supersededAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, category, createdAt])
  @@index([supersededAt])
}

model CreatorApplication {
  id                 String    @id @default(cuid())
  userId             String    @unique
  status             String    @default("DRAFT") // DRAFT|SUBMITTED|UNDER_REVIEW|APPROVED|REJECTED
  displayName        String    @default("")
  username           String    @default("")
  bio                String    @default("")
  categoryTags       String    @default("[]")
  legalFullName      String    @default("")
  dateOfBirth        DateTime?
  nationality        String    @default("")
  country            String    @default("")
  phone              String    @default("")
  idType             String    @default("IC") // IC|PASSPORT
  idNumber           String    @default("")
  idOtherDescription String    @default("")
  idFrontImage       String?
  idBackImage        String?
  selfieImage        String?
  kycCompleted       Boolean   @default(false)
  bankCountryCode    String    @default("")
  bankCurrency       String    @default("")
  bankAccountName    String    @default("")
  bankName           String    @default("")
  bankCode           String    @default("")
  bankAccountNumber  String    @default("")
  bankRoutingCode    String    @default("")
  paypalEmail        String?
  adminNote          String?
  rejectionReason    String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedBy         String?
  // Orphan housekeeping: day-5 reminder, day-7 purge for DRAFT applications inactive 7+ days.
  kycReminderSentAt  DateTime?
  orphanedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([status, updatedAt])
  @@index([orphanedAt])
}

// ── Dispute Evidence (append-only) ────────────────────────────────────────────
//
// Every image attached to a dispute (by raiser or creator) is tracked in this
// table — both when first uploaded and when the uploader wants to correct a
// previous upload. Users never delete; the superseded row is kept so the
// admin can always see the full history (prevents "change of argument" abuse).
// The only code path that removes rows + R2 objects is admin housekeeping.
model DisputeEvidence {
  id           String    @id @default(cuid())
  disputeId    String
  uploaderId   String // User.id — raiser or creator (whoever attached the file)
  role         String // "RAISER" | "CREATOR"
  r2Key        String
  viewerUrl    String
  mimeType     String?
  fileSize     Int?
  note         String? // free-text caption shown with the evidence
  uploadedAt   DateTime  @default(now())
  supersededBy String?   @unique
  supersededAt DateTime?

  dispute Dispute @relation(fields: [disputeId], references: [id])

  @@index([disputeId, uploadedAt])
  @@index([uploaderId])
  @@index([supersededAt])
}

// ── Private File Access Audit ─────────────────────────────────────────────────
//
// Every admin read of a private bucket file (KYC image, dispute evidence,
// message attachment) writes one row. Required for compliance: "who looked
// at whose ID, when, and why". Reason codes are enumerated client-side so
// we can report on them. Admins must supply a reason via X-Access-Reason
// header; the streaming endpoint rejects requests without one.
model PrivateFileAccess {
  id           String   @id @default(cuid())
  actorType    String // STAFF | OWNER | SYSTEM
  actorId      String? // StaffUser.id (STAFF) or User.id (OWNER) or cron slug (SYSTEM, nullable)
  actorName    String // denormalized actor name/email snapshot (survives renames)
  targetUserId String? // User.id the file belongs to
  category     String // identity | dispute-evidence | message-attachment | kyc
  r2Key        String
  reasonCode   String // KYC_REVIEW | DISPUTE_REVIEW | COMPLIANCE_AUDIT | CS_TICKET | OWNER_SELF_VIEW | LEGAL_REQUEST | OTHER
  reasonNote   String? // free-text justification (required when reasonCode = OTHER)
  ipAddress    String?
  userAgent    String?
  accessedAt   DateTime @default(now())

  @@index([targetUserId, accessedAt])
  @@index([actorId, accessedAt])
  @@index([category, accessedAt])
}

// ── Private File Deletion Audit ───────────────────────────────────────────────
//
// Admin-only deletion log. Every call to deleteFromR2 for a private-prefix
// object must write a row here first. The admin UI enforces a reason code
// and policy tag. No row → no deletion (enforced in housekeeping code path).
model PrivateFileDeletion {
  id            String   @id @default(cuid())
  actorType     String // STAFF | SYSTEM
  actorId       String? // StaffUser.id for STAFF, cron slug for SYSTEM
  actorName     String
  targetUserId  String? // owner of the file at deletion time
  category      String // identity | dispute-evidence | message-attachment | kyc
  r2Key         String
  reasonCode    String // ORPHAN_PURGE | KYC_RETENTION_EXPIRED | DISPUTE_RETENTION_EXPIRED | LEGAL_REQUEST | GDPR_ERASURE | DUPLICATE | TEST_DATA | OTHER
  reasonNote    String?
  policyApplied String? // e.g. "KYC_REJECTED_90D" or "DISPUTE_CLOSED_540D"
  ipAddress     String?
  deletedAt     DateTime @default(now())

  @@index([targetUserId, deletedAt])
  @@index([actorId, deletedAt])
  @@index([category, deletedAt])
}

// ── Staff System ──────────────────────────────────────────────────────────────

model StaffUser {
