generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String?
  googleId           String?  @unique
  name               String
  role               String   @default("BUYER")
  avatar             String?
  phone              String?
  warningCount       Int      @default(0)
  isFlaggedForReview Boolean  @default(false)
  payoutFrozen       Boolean  @default(false)
  payoutFrozenReason String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Creator onboarding & verification
  creatorVerificationStatus String    @default("UNVERIFIED") // UNVERIFIED|PENDING|VERIFIED|REJECTED
  creatorVerificationNote   String?
  accountStatus             String    @default("ACTIVE") // ACTIVE|RESTRICTED|SUSPENDED|CLOSED
  restrictedAt              DateTime?
  restrictionReason         String?
  closureRequestedAt        DateTime?
  agreementsLastCheckedAt   DateTime?
  agreementSkipCount        Int       @default(0)
  legalFullName             String?
  airwallexCustomerId       String?

  creatorProfile       CreatorProfile?
  supportSubscriptions SupportSubscription[] @relation("SupportSubscriber")
  supportTransactions  SupportTransaction[]  @relation("SupporterUser")
  buyerOrders          Order[]               @relation("BuyerOrders")
  creatorOrders        Order[]               @relation("CreatorOrders")
  sentMessages         Message[]             @relation("SentMessages")
  receivedMessages     Message[]             @relation("ReceivedMessages")
  buyerConvos          Conversation[]        @relation("BuyerConvos")
  creatorConvos        Conversation[]        @relation("CreatorConvos")
  payouts              Payout[]
  invoices             Invoice[]
  media                Media[]
  posts                Post[]                @relation("PostAuthor")
  notifications        Notification[]
  raisedDisputes       Dispute[]             @relation("DisputeRaisedBy")
  resolvedDisputes     Dispute[]             @relation("DisputeResolvedBy")
  escrowTransactions   EscrowTransaction[]
  wishlistItems        WishlistItem[]
  following            CreatorFollow[]
  cartItems            CartItem[]
  creatorApplication   CreatorApplication?
  creatorAgreements    CreatorAgreement[]
  reviews              ProductReview[]
  guestbookEntries     CreatorGuestbook[]

  // Commission request/quote (as buyer)
  buyerCommissionRequests CommissionRequest[] @relation("BuyerCommissionRequests")
  buyerCommissionQuotes   CommissionQuote[]   @relation("BuyerCommissionQuotes")

  // Storage plan
  storagePlan         String               @default("FREE") // FREE | CREATOR | PRO
  storagePlanRenewsAt DateTime?
  storageBonusMb      Int                  @default(0) // admin-granted extra quota
  storageOverageBytes BigInt               @default(0) // accumulated overage
  storageSubscription StorageSubscription?

  @@index([role])
  @@index([accountStatus])
  @@index([creatorVerificationStatus])
}

model CreatorProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  username               String    @unique
  displayName            String
  bio                    String?
  bannerImage            String?
  avatar                 String?
  socialLinks            String    @default("{}")
  categoryTags           String    @default("[]")
  commissionStatus       String    @default("OPEN")
  announcementText       String?
  announcementActive     Boolean   @default(false)
  featuredProductIds     String    @default("[]")
  isVerified             Boolean   @default(false)
  isTopCreator           Boolean   @default(false)
  totalSales             Int       @default(0)
  absorbProcessingFee    Boolean   @default(false)
  portfolioItems         String    @default("[]")
  isSuspended            Boolean   @default(false)
  badges                 String    @default("[]")
  commissionSlots        Int?
  commissionTerms        String?
  commissionPricing      String    @default("[]")
  commissionDescription  String?
  commissionDefaults     String    @default("{}") // JSON: { depositPercent, revisionsIncluded, turnaroundDays, milestoneTemplates: [{name, stages: [{label, percent}]}], preferMilestones }
  logoImage              String?
  popupEnabled           Boolean   @default(false)
  popupTitle             String?
  popupDescription       String?
  popupCtaText           String?
  popupCtaLink           String?
  popupBadgeText         String?
  popupImageUrl          String?
  notifPrefs             String    @default("{}")
  themeColor             String?
  sectionOrder           String    @default("[]")
  storeStatus            String    @default("ACTIVE") // ACTIVE | IDLE | HIATUS | FLAGGED
  storeStatusReason      String?
  storeStatusUpdatedAt   DateTime?
  lastLoginAt            DateTime?
  fulfillmentWarnings    Int       @default(0)
  healthEmailSentAt      String? // JSON: { nudge30, reengagement, fulfillmentWarn, preSuspension }
  onboardingCompleted    Boolean   @default(false)
  onboardingDismissed    Boolean   @default(false)
  airwallexBeneficiaryId String?
  payoutMethod           String    @default("bank_transfer")
  boostMultiplier        Float     @default(1.0)
  lastFeaturedAt         DateTime?
  payoutDetails          String? // AES-256 encrypted JSON
  payoutCountry          String?
  payoutCurrency         String?
  createdAt              DateTime  @default(now())

  user                 User                  @relation(fields: [userId], references: [id])
  products             Product[]
  videos               Video[]
  supportTiers         SupportTier[]
  supportGoals         SupportGoal[]
  supportGift          SupportGift?
  supportTransactions  SupportTransaction[]
  supportSubscriptions SupportSubscription[]
  podProviders         CreatorPodProvider[]
  followers            CreatorFollow[]
  guestbookEntries     CreatorGuestbook[]
  discountCodes        DiscountCode[]
  commissionRequests   CommissionRequest[]
  commissionQuotes     CommissionQuote[]
}

// ── POD Provider ──────────────────────────────────────────────────────────────

model CreatorPodProvider {
  id                    String   @id @default(cuid())
  creatorId             String
  name                  String // PRINTIFY|PRINTFUL|MERCHIZE|CJ_DROPSHIPPING|GOOTEN|LOCAL_PRINT_SHOP|SELF_FULFILLED|OTHER
  customName            String?
  storeUrl              String?
  notes                 String?
  isDefault             Boolean  @default(false)
  defaultProductionDays Int      @default(5)
  shippingMY            Int      @default(5)
  shippingSG            Int      @default(7)
  shippingPH            Int      @default(10)
  shippingIntl          Int      @default(14)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  creator  CreatorProfile @relation(fields: [creatorId], references: [id])
  products Product[]
}

// ── Product ───────────────────────────────────────────────────────────────────

model Product {
  id                          String    @id @default(cuid())
  creatorId                   String
  title                       String
  description                 String
  price                       Int
  category                    String
  type                        String // DIGITAL | PHYSICAL | POD | COMMISSION
  // Commission-specific
  commissionDepositPercent    Int?
  commissionRevisionsIncluded Int?
  commissionTurnaroundDays    Int?
  images                      String    @default("[]")
  digitalFile                 String?
  digitalFiles                String? // JSON array of { key, filename, size, mime }
  stock                       Int?
  isActive                    Boolean   @default(true)
  isPinned                    Boolean   @default(false)
  order                       Int       @default(0)
  // POD fields
  podProviderId               String?
  baseCost                    Int?
  productionDays              Int?
  shippingMY                  Int?
  shippingSG                  Int?
  shippingPH                  Int?
  shippingIntl                Int?
  showProviderPublic          Boolean   @default(false)
  podExternalUrl              String?
  sizeVariants                String? // JSON array of size strings
  colorVariants               String? // JSON array of {name, mockupImage}
  trendingScore               Float     @default(0)
  trendingVersion             Int       @default(1)
  trendingUpdatedAt           DateTime?
  manualBoost                 Int       @default(0)
  isTrendingSuppressed        Boolean   @default(false)
  reviewCount                 Int       @default(0)
  averageRating               Float     @default(0)
  isPreOrder                  Boolean   @default(false)
  preOrderMessage             String?
  preOrderReleaseAt           DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  creator               CreatorProfile          @relation(fields: [creatorId], references: [id])
  podProvider           CreatorPodProvider?     @relation(fields: [podProviderId], references: [id])
  orders                Order[]
  wishlistItems         WishlistItem[]
  cartItems             CartItem[]
  views                 ProductView[]
  trendingScoreRecord   ProductTrendingScore?
  sourceRecommendations ProductRecommendation[] @relation("SourceProduct")
  targetRecommendations ProductRecommendation[] @relation("TargetProduct")
  reviews               ProductReview[]
  discountCodes         DiscountCode[]
}

// ── Product View Tracking ──────────────────────────────────────────────────────

model ProductView {
  id        String   @id @default(cuid())
  productId String
  sessionId String
  userId    String?
  ipAddress String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
  @@index([ipAddress, productId, createdAt])
  @@index([sessionId, productId, createdAt])
}

// ── Trending Score Shadow Table ────────────────────────────────────────────────

model ProductTrendingScore {
  id           String   @id @default(cuid())
  productId    String   @unique
  version      Int
  score        Float
  breakdown    String // JSON: { orders_7d, wishlist_7d, cart_7d, views_7d, raw, decay_applied, manualBoost, final, version }
  calculatedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ── Product Recommendations ────────────────────────────────────────────────────

model ProductRecommendation {
  id                   String   @id @default(cuid())
  sourceProductId      String
  recommendedProductId String
  score                Float
  sharedBuyers         Int
  computedAt           DateTime @default(now())

  sourceProduct      Product @relation("SourceProduct", fields: [sourceProductId], references: [id], onDelete: Cascade)
  recommendedProduct Product @relation("TargetProduct", fields: [recommendedProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, recommendedProductId])
  @@index([sourceProductId, score(sort: Desc)])
}

// ── Product Reviews ────────────────────────────────────────────────────────────

model ProductReview {
  id           String   @id @default(cuid())
  productId    String
  orderId      String?  @unique
  buyerId      String
  rating       Int
  title        String?
  body         String?
  isVerified   Boolean  @default(false)
  isVisible    Boolean  @default(false)
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])
  buyer   User    @relation(fields: [buyerId], references: [id])

  @@unique([productId, buyerId])
  @@index([productId, createdAt])
  @@index([buyerId])
}

model CreatorGuestbook {
  id               String   @id @default(cuid())
  creatorProfileId String
  authorId         String
  content          String
  rating           Int?
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  isVisible        Boolean  @default(false)
  createdAt        DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id])
  author         User           @relation(fields: [authorId], references: [id])

  @@index([creatorProfileId, createdAt])
  @@index([authorId])
}

// ── Order ─────────────────────────────────────────────────────────────────────

model Order {
  id                             String    @id @default(cuid())
  buyerId                        String
  creatorId                      String
  productId                      String
  status                         String    @default("PENDING")
  amountUsd                      Int
  displayCurrency                String    @default("USD")
  displayAmount                  Int       @default(0)
  exchangeRate                   Float     @default(1.0)
  exchangeRateAt                 DateTime?
  cartSessionId                  String?
  airwallexIntentId              String?
  trackingNumber                 String?
  courierName                    String?
  courierCode                    String?
  trackingAddedAt                DateTime?
  estimatedDelivery              DateTime?
  shippingAddress                String?
  downloadToken                  String?
  downloadExpiry                 DateTime?
  // Escrow
  escrowStatus                   String    @default("HELD") // HELD|TRACKING_ADDED|RELEASED|DISPUTED|REFUNDED|PARTIALLY_REFUNDED
  escrowHeldAt                   DateTime?
  escrowReleasedAt               DateTime?
  escrowAutoReleaseAt            DateTime?
  fulfillmentDeadline            DateTime?
  fulfillmentWarningsSent        Int       @default(0)
  buyerConfirmedAt               DateTime?
  discountCodeId                 String?
  discountAmount                 Int       @default(0)
  // Commission fields
  commissionStatus               String? // PENDING_ACCEPTANCE|ACCEPTED|DELIVERED|REVISION_REQUESTED|COMPLETED
  commissionBriefText            String?
  commissionReferenceImages      String? // JSON array of URLs
  commissionDepositPercent       Int? // snapshot at order time
  commissionDepositAmount        Int? // cents
  commissionRevisionsAllowed     Int? // snapshot
  commissionRevisionsUsed        Int       @default(0)
  commissionAcceptedAt           DateTime?
  commissionDeliveredAt          DateTime?
  commissionDeliveryFiles        String? // JSON array of URLs
  commissionAcceptDeadlineAt     DateTime? // 48h from order creation
  commissionBuyerAcceptedAt      DateTime?
  commissionDepositConsentAt     DateTime? // when buyer consented to deposit release at checkout
  commissionDepositAutoReleaseAt DateTime? // 48h after creator acceptance + new creator modifier
  commissionDepositReleasedAt    DateTime? // when deposit portion was actually released to creator
  // Quote-based commissions (Lane B + C)
  commissionQuoteId              String?   @unique // if this Order came from an accepted CommissionQuote
  commissionIsMilestoneBased     Boolean   @default(false)
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  buyer              User                  @relation("BuyerOrders", fields: [buyerId], references: [id])
  creator            User                  @relation("CreatorOrders", fields: [creatorId], references: [id])
  product            Product               @relation(fields: [productId], references: [id])
  transactions       Transaction[]
  messages           Message[]
  invoices           Invoice[]
  dispute            Dispute?
  escrowTransactions EscrowTransaction[]
  review             ProductReview?
  discountCode       DiscountCode?         @relation(fields: [discountCodeId], references: [id])
  chargebacks        ChargebackDispute[]
  commissionQuote    CommissionQuote?      @relation(fields: [commissionQuoteId], references: [id])
  milestones         CommissionMilestone[]

  @@index([airwallexIntentId])
  @@index([escrowAutoReleaseAt])
  @@index([status, createdAt])
  @@index([buyerId, createdAt])
  @@index([creatorId, status])
}

// ── Dispute ───────────────────────────────────────────────────────────────────

model Dispute {
  id                 String    @id @default(cuid())
  orderId            String    @unique
  raisedBy           String
  reason             String // NEVER_ARRIVED|WRONG_ITEM|PRINT_QUALITY|WRONG_SIZE|DAMAGED|OTHER
  description        String
  evidence           String    @default("[]") // JSON array of image URLs
  creatorResponse    String?
  creatorEvidence    String? // JSON array
  creatorRespondedAt DateTime?
  status             String    @default("OPEN") // OPEN|UNDER_REVIEW|RESOLVED_REFUND|RESOLVED_RELEASE|CLOSED
  adminNote          String?
  resolvedBy         String?
  resolvedAt         DateTime?
  refundAmount       Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  order    Order @relation(fields: [orderId], references: [id])
  raiser   User  @relation("DisputeRaisedBy", fields: [raisedBy], references: [id])
  resolver User? @relation("DisputeResolvedBy", fields: [resolvedBy], references: [id])
}

// ── Escrow Transaction ────────────────────────────────────────────────────────

model EscrowTransaction {
  id          String   @id @default(cuid())
  orderId     String
  milestoneId String?
  type        String // HOLD|RELEASE|REFUND|PARTIAL_REFUND|ADMIN_RELEASE|MILESTONE_RELEASE
  amount      Int
  note        String?
  performedBy String?
  createdAt   DateTime @default(now())

  order     Order                @relation(fields: [orderId], references: [id])
  performer User?                @relation(fields: [performedBy], references: [id])
  milestone CommissionMilestone? @relation(fields: [milestoneId], references: [id])
}

// ── Notification ──────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // NEW_ORDER|FULFILLMENT_REMINDER|FULFILLMENT_WARNING|FULFILLMENT_FINAL_WARNING|ORDER_CANCELLED|ESCROW_RELEASED|NEW_MESSAGE|DISPUTE_RAISED|DISPUTE_RESOLVED|PAYOUT_PROCESSED|ORDER_CONFIRMED|ORDER_SHIPPED|DOWNLOAD_READY|REFUND_ISSUED
  title     String
  message   String
  orderId   String?
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ── Transaction ───────────────────────────────────────────────────────────────

model Transaction {
  id                 String   @id @default(cuid())
  orderId            String
  buyerId            String
  creatorId          String
  grossAmountUsd     Int
  processingFee      Int
  platformFee        Int      @default(0)
  withdrawalFee      Int      @default(0)
  creatorAmount      Int
  currency           String   @default("USD")
  airwallexReference String?
  status             String   @default("PENDING")
  createdAt          DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model Payout {
  id                  String    @id @default(cuid())
  creatorId           String
  amountUsd           Int
  currency            String    @default("USD")
  status              String    @default("PENDING")
  airwallexPayoutId   String?
  requestedAt         DateTime  @default(now())
  completedAt         DateTime?
  processedAt         DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?
  adminNote           String?
  payoutMethod        String    @default("bank_transfer")
  accountDetails      String?
  airwallexTransferId String?
  failureReason       String?

  creator User @relation(fields: [creatorId], references: [id])
}

model Invoice {
  id              String   @id @default(cuid())
  type            String
  referenceNumber String   @unique
  issuedToId      String
  issuedToType    String
  amountUsd       Int
  items           String   @default("[]")
  pdfPath         String?
  orderId         String?
  createdAt       DateTime @default(now())

  issuedTo User   @relation(fields: [issuedToId], references: [id])
  order    Order? @relation(fields: [orderId], references: [id])
}

model Message {
  id           String   @id @default(cuid())
  senderId     String
  receiverId   String
  orderId      String?
  content      String
  imageUrl     String?
  attachments  String   @default("[]") // JSON: [{url, type, name, size}]
  isRead       Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  sender   User   @relation("SentMessages", fields: [senderId], references: [id])
  receiver User   @relation("ReceivedMessages", fields: [receiverId], references: [id])
  order    Order? @relation(fields: [orderId], references: [id])
}

model Conversation {
  id            String   @id @default(cuid())
  buyerId       String
  creatorId     String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  buyer   User @relation("BuyerConvos", fields: [buyerId], references: [id])
  creator User @relation("CreatorConvos", fields: [creatorId], references: [id])

  @@unique([buyerId, creatorId])
  @@index([lastMessageAt])
  @@index([buyerId, lastMessageAt])
  @@index([creatorId, lastMessageAt])
}

model Page {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  content        String?
  status         String   @default("DRAFT")
  showInFooter   Boolean  @default(false)
  footerColumn   String?
  footerOrder    Int?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Post {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  excerpt        String?
  content        String?
  coverImage     String?
  authorId       String
  status         String    @default("DRAFT")
  publishedAt    DateTime?
  scheduledAt    DateTime?
  tags           String    @default("[]")
  seoTitle       String?
  seoDescription String?
  viewCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  author User @relation("PostAuthor", fields: [authorId], references: [id])
}

model Section {
  id        String   @id @default(cuid())
  pageSlug  String
  type      String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  content   String   @default("{}")
  updatedAt DateTime @updatedAt
}

model Media {
  id         String   @id @default(cuid())
  filename   String
  url        String
  uploadedBy String
  fileSize   Int?
  width      Int?
  height     Int?
  mimeType   String?
  createdAt  DateTime @default(now())

  uploader User @relation(fields: [uploadedBy], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  text      String
  link      String?
  color     String   @default("#7c3aed")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BuyerTag {
  id        String   @id @default(cuid())
  creatorId String
  buyerId   String
  tags      String   @default("[]")
  notes     String?
  updatedAt DateTime @updatedAt

  @@unique([creatorId, buyerId])
}

model Video {
  id          String   @id @default(cuid())
  creatorId   String
  title       String
  description String?
  platform    String   @default("YOUTUBE")
  url         String
  embedId     String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  creator CreatorProfile @relation(fields: [creatorId], references: [id])
}

model SupportTier {
  id              String   @id @default(cuid())
  creatorId       String
  name            String
  description     String?
  priceUsd        Int
  perks           String   @default("[]")
  isActive        Boolean  @default(true)
  subscriberCount Int      @default(0)
  order           Int      @default(0)
  createdAt       DateTime @default(now())

  creator       CreatorProfile        @relation(fields: [creatorId], references: [id])
  subscriptions SupportSubscription[]
}

model SupportGoal {
  id               String    @id @default(cuid())
  creatorId        String
  title            String
  description      String?
  targetAmountUsd  Int
  currentAmountUsd Int       @default(0)
  deadline         DateTime?
  status           String    @default("ACTIVE")
  coverImage       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  creator CreatorProfile @relation(fields: [creatorId], references: [id])
}

model SupportGift {
  id                 String  @id @default(cuid())
  creatorId          String  @unique
  isActive           Boolean @default(true)
  presetAmounts      String  @default("[3,5,10,25]")
  thankYouMessage    String  @default("Thank you for your support!")
  totalReceived      Int     @default(0)
  giftCount          Int     @default(0)
  monthlyGiftCount   Int     @default(0)
  monthlyGifterCount Int     @default(0)

  creator CreatorProfile @relation(fields: [creatorId], references: [id])
}

model SupportTransaction {
  id                String   @id @default(cuid())
  creatorId         String
  supporterId       String?
  type              String // GIFT | GOAL | TIER | MONTHLY_GIFT
  amountUsd         Int
  currency          String   @default("USD")
  tierId            String?
  goalId            String?
  subscriptionId    String?
  message           String?
  isAnonymous       Boolean  @default(false)
  isMonthly         Boolean  @default(false)
  status            String   @default("PAID") // PENDING | PAID | FAILED | REFUNDED
  airwallexIntentId String?
  processingFee     Int      @default(0)
  creatorAmount     Int      @default(0)
  createdAt         DateTime @default(now())

  creator      CreatorProfile       @relation(fields: [creatorId], references: [id])
  supporter    User?                @relation("SupporterUser", fields: [supporterId], references: [id])
  subscription SupportSubscription? @relation(fields: [subscriptionId], references: [id])

  @@index([creatorId, createdAt])
  @@index([airwallexIntentId])
}

model SupportSubscription {
  id                        String    @id @default(cuid())
  supporterId               String
  creatorId                 String
  tierId                    String?
  type                      String // TIER | MONTHLY_GIFT
  amountUsd                 Int
  currency                  String    @default("USD")
  status                    String    @default("PENDING") // PENDING | ACTIVE | PAST_DUE | CANCELED
  airwallexCustomerId       String
  airwallexPaymentConsentId String?
  airwallexInitialIntentId  String?
  currentPeriodStart        DateTime?
  currentPeriodEnd          DateTime?
  cancelAtPeriodEnd         Boolean   @default(false)
  canceledAt                DateTime?
  failedChargeCount         Int       @default(0)
  lastChargedAt             DateTime?
  nextRetryAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  supporter    User                 @relation("SupportSubscriber", fields: [supporterId], references: [id])
  creator      CreatorProfile       @relation(fields: [creatorId], references: [id])
  tier         SupportTier?         @relation(fields: [tierId], references: [id])
  transactions SupportTransaction[]

  @@index([supporterId, status])
  @@index([creatorId, status])
  @@index([status, currentPeriodEnd])
}

model PopupAd {
  id          String    @id @default(cuid())
  title       String
  description String?
  imageUrl    String?
  ctaText     String
  ctaLink     String
  isActive    Boolean   @default(false)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PlatformSettings {
  id                             String  @id @default(cuid())
  processingFeePercent           Float   @default(2.5)
  platformFeePercent             Float   @default(0.0)
  withdrawalFeePercent           Float   @default(4.0)
  topCreatorThreshold            Int     @default(100)
  // Escrow policy
  digitalEscrowHours             Int     @default(48)
  physicalEscrowDays             Int     @default(14)
  podEscrowDays                  Int     @default(30)
  commissionEscrowDays           Int     @default(30)
  newCreatorEscrowExtraDays      Int     @default(7)
  newCreatorTransactionThreshold Int     @default(10)
  maintenanceMode                Boolean @default(false)
  maintenanceMessage             String?
}

model NavItem {
  id              String   @id @default(cuid())
  label           String
  url             String   @default("#")
  navType         String   @default("SECONDARY")
  position        String   @default("LEFT")
  order           Int      @default(0)
  dropdownType    String   @default("NONE")
  dropdownContent String   @default("{}")
  openInNewTab    Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Cart ──────────────────────────────────────────────────────────────────────

model CartItem {
  id            String   @id @default(cuid())
  buyerId       String
  productId     String
  quantity      Int      @default(1)
  selectedSize  String?
  selectedColor String?
  addedAt       DateTime @default(now())

  buyer   User    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ── Discount Codes ────────────────────────────────────────────────────────────

model DiscountCode {
  id                 String    @id @default(cuid())
  code               String    @unique
  type               String // PERCENTAGE | FIXED_AMOUNT
  value              Int // percentage (0-100) or cents
  minimumOrderAmount Int? // cents, optional
  maxUses            Int? // null = unlimited
  usedCount          Int       @default(0)
  expiresAt          DateTime?
  isActive           Boolean   @default(true)
  creatorId          String
  productId          String?
  createdAt          DateTime  @default(now())

  creator CreatorProfile @relation(fields: [creatorId], references: [id])
  product Product?       @relation(fields: [productId], references: [id])
  orders  Order[]
}

// ── Wishlist ──────────────────────────────────────────────────────────────────

model WishlistItem {
  id                String   @id @default(cuid())
  buyerId           String
  productId         String
  notifyPriceChange Boolean  @default(true)
  notifyRestock     Boolean  @default(true)
  notifyNewDrop     Boolean  @default(false)
  addedAt           DateTime @default(now())

  buyer   User    @relation(fields: [buyerId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([buyerId, productId])
}

// ── Creator Follow ────────────────────────────────────────────────────────────

model CreatorFollow {
  id                   String   @id @default(cuid())
  buyerId              String
  creatorId            String
  notifyNewProduct     Boolean  @default(true)
  notifyCommissionOpen Boolean  @default(true)
  notifyNewPost        Boolean  @default(false)
  followedAt           DateTime @default(now())

  buyer   User           @relation(fields: [buyerId], references: [id])
  creator CreatorProfile @relation(fields: [creatorId], references: [id])

  @@unique([buyerId, creatorId])
}

// ── Email Log ─────────────────────────────────────────────────────────────────

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  type      String
  status    String   @default("sent")
  resendId  String?
  error     String?
  createdAt DateTime @default(now())
}

// ── Password Reset ────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ── Storage ───────────────────────────────────────────────────────────────────

model StoragePricingConfig {
  id                    String   @id @default("config")
  freePlanMb            Int      @default(2048) // 2GB
  // New tier names (current policy)
  creatorPlanGb         Int      @default(25)
  creatorPlanPriceCents Int      @default(690) // $6.90/mo
  // proPlanGb/proPlanPriceCents repurposed: now the top tier (was 5GB @ $9.99 in v1)
  proPlanGb             Int      @default(100)
  proPlanPriceCents     Int      @default(1490) // $14.90/mo
  overageCentsPerGb     Int      @default(8) // $0.08/GB soft overage
  overageGracePercent   Int      @default(10) // grace before overage kicks in
  // Legacy columns (v1 tiers + top-ups) kept for data preservation; no longer read by app
  studioPlanGb          Int      @default(20)
  studioPlanPriceCents  Int      @default(1999)
  topup1gbCents         Int      @default(299)
  topup5gbCents         Int      @default(999)
  topup10gbCents        Int      @default(1799)
  warningThreshold1     Int      @default(80)
  warningThreshold2     Int      @default(95)
  gracePeriodDays       Int      @default(7)
  orphanAgeDays         Int      @default(30)
  deleteWarningHours    Int      @default(48)
  feeGraceDays          Int      @default(7)
  feePayoutBlockDays    Int      @default(14)
  feeSuspendDays        Int      @default(30)
  updatedAt             DateTime @updatedAt
}

model StoragePurchase {
  id          String   @id @default(cuid())
  userId      String
  planType    String
  amountCents Int
  status      String   @default("INTEREST")
  createdAt   DateTime @default(now())
}

model StorageSubscription {
  id                        String    @id @default(cuid())
  userId                    String    @unique
  plan                      String // CREATOR | PRO
  priceCents                Int
  status                    String    @default("PENDING") // PENDING | ACTIVE | PAST_DUE | CANCELED
  airwallexCustomerId       String
  airwallexPaymentConsentId String?
  airwallexInitialIntentId  String?
  currentPeriodStart        DateTime?
  currentPeriodEnd          DateTime?
  cancelAtPeriodEnd         Boolean   @default(false)
  canceledAt                DateTime?
  failedChargeCount         Int       @default(0)
  lastChargedAt             DateTime?
  nextRetryAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([status, currentPeriodEnd])
}

// ── Commission Requests & Quotes ──────────────────────────────────────────────

model CommissionRequest {
  id                String    @id @default(cuid())
  buyerId           String
  creatorId         String // CreatorProfile.id
  title             String
  briefText         String
  referenceImages   String    @default("[]") // JSON array of URLs
  budgetMinUsd      Int?
  budgetMaxUsd      Int?
  deadlineAt        DateTime?
  status            String    @default("PENDING") // PENDING | QUOTED | ACCEPTED | DECLINED | WITHDRAWN | EXPIRED
  declineReason     String?
  creatorResponseAt DateTime?
  expiresAt         DateTime // 7 days default
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  buyer   User              @relation("BuyerCommissionRequests", fields: [buyerId], references: [id])
  creator CreatorProfile    @relation(fields: [creatorId], references: [id])
  quotes  CommissionQuote[]

  @@index([buyerId, status])
  @@index([creatorId, status])
  @@index([status, expiresAt])
}

model CommissionQuote {
  id                String    @id @default(cuid())
  requestId         String? // nullable — creator may send standalone quote
  creatorId         String // CreatorProfile.id
  buyerId           String
  title             String
  description       String
  amountUsd         Int
  depositPercent    Int       @default(0)
  revisionsIncluded Int       @default(1)
  turnaroundDays    Int
  termsText         String?
  isMilestoneBased  Boolean   @default(false)
  status            String    @default("DRAFT") // DRAFT | SENT | ACCEPTED | REJECTED | EXPIRED | WITHDRAWN
  expiresAt         DateTime // 7d from SENT
  sentAt            DateTime?
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  request    CommissionRequest?    @relation(fields: [requestId], references: [id])
  creator    CreatorProfile        @relation(fields: [creatorId], references: [id])
  buyer      User                  @relation("BuyerCommissionQuotes", fields: [buyerId], references: [id])
  milestones CommissionMilestone[]
  order      Order? // set when buyer accepts + pays

  @@index([creatorId, status])
  @@index([buyerId, status])
  @@index([status, expiresAt])
}

model CommissionMilestone {
  id               String    @id @default(cuid())
  quoteId          String
  orderId          String? // populated when quote accepted → Order created
  order            Int       @default(0) // sequence
  title            String
  description      String?
  amountUsd        Int
  status           String    @default("PENDING") // PENDING | IN_PROGRESS | DELIVERED | APPROVED | REVISION_REQUESTED | COMPLETED | REFUNDED
  deliveredAt      DateTime?
  deliveryFiles    String? // JSON array of { key, filename, size, mime }
  deliveryNote     String?
  approvedAt       DateTime?
  revisionNote     String?
  autoReleaseAt    DateTime? // 14 days after delivery
  releasedAt       DateTime?
  revisionsUsed    Int       @default(0)
  revisionsAllowed Int       @default(1)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  quote         CommissionQuote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  orderRef      Order?              @relation(fields: [orderId], references: [id])
  escrowEntries EscrowTransaction[]

  @@index([quoteId, order])
  @@index([orderId, status])
  @@index([status, autoReleaseAt])
}

// ── Creator Onboarding ────────────────────────────────────────────────────────

model AgreementTemplate {
  id            String    @id @default(cuid())
  type          String // CREATOR_TOS|IP_DECLARATION|PAYMENT_TERMS|PRIVACY_POLICY|COMMUNITY_GUIDELINES
  version       String
  title         String
  content       String
  summary       String
  changeLog     String?
  effectiveDate DateTime
  isActive      Boolean   @default(false)
  createdBy     String
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?

  agreements CreatorAgreement[]
}

model CreatorAgreement {
  id                String   @id @default(cuid())
  userId            String
  templateId        String
  agreementType     String
  agreementVersion  String
  agreedAt          DateTime @default(now())
  ipAddress         String
  userAgent         String
  signedName        String
  agreementSnapshot String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id])
  template AgreementTemplate @relation(fields: [templateId], references: [id])
}

model CreatorApplication {
  id                 String    @id @default(cuid())
  userId             String    @unique
  status             String    @default("DRAFT") // DRAFT|SUBMITTED|UNDER_REVIEW|APPROVED|REJECTED
  displayName        String    @default("")
  username           String    @default("")
  bio                String    @default("")
  categoryTags       String    @default("[]")
  legalFullName      String    @default("")
  dateOfBirth        DateTime?
  nationality        String    @default("")
  country            String    @default("")
  phone              String    @default("")
  idType             String    @default("IC") // IC|PASSPORT
  idNumber           String    @default("")
  idOtherDescription String    @default("")
  idFrontImage       String?
  idBackImage        String?
  selfieImage        String?
  kycCompleted       Boolean   @default(false)
  bankCountryCode    String    @default("")
  bankCurrency       String    @default("")
  bankAccountName    String    @default("")
  bankName           String    @default("")
  bankCode           String    @default("")
  bankAccountNumber  String    @default("")
  bankRoutingCode    String    @default("")
  paypalEmail        String?
  adminNote          String?
  rejectionReason    String?
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewedBy         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ── Staff System ──────────────────────────────────────────────────────────────

model StaffUser {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String
  department     String?
  passwordHash   String
  isSuperAdmin   Boolean   @default(false)
  isActive       Boolean   @default(true)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastLogin      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  permissions StaffUserPermission[]
  auditEvents AuditEvent[]
}

model StaffPermission {
  id          String   @id @default(cuid())
  shortcode   String   @unique // format: component.action e.g. "creators.suspend"
  displayName String
  description String?
  component   String
  action      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userGrants StaffUserPermission[]
}

model StaffUserPermission {
  id                String    @id @default(cuid())
  staffUserId       String
  staffPermissionId String
  assignedAt        DateTime  @default(now())
  assignedById      String?
  expiresAt         DateTime?

  staffUser       StaffUser       @relation(fields: [staffUserId], references: [id])
  staffPermission StaffPermission @relation(fields: [staffPermissionId], references: [id])

  @@unique([staffUserId, staffPermissionId])
}

model StaffRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorId     String?
  actorName   String
  action      String
  entityType  String
  entityId    String
  entityLabel String?
  reason      String?
  beforeJson  String?
  afterJson   String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor StaffUser? @relation(fields: [actorId], references: [id])
}

// ── Creator Spotlight ─────────────────────────────────────────────────────────

model CreatorSpotlight {
  id             String   @id @default(cuid())
  displayName    String
  creatorType    String
  location       String
  quote          String
  earningsStat   String
  earningsPeriod String
  avatarInitials String
  avatarColor    String
  profileUrl     String?
  isActive       Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
}

// ── Chargeback Disputes ───────────────────────────────────────────────────────

model ChargebackDispute {
  id                 String    @id @default(cuid())
  airwallexDisputeId String    @unique
  orderId            String
  paymentIntentId    String
  amountUsd          Int
  currency           String    @default("USD")
  reason             String // FRAUD|DUPLICATE|PRODUCT_NOT_RECEIVED|CREDIT_NOT_PROCESSED|GENERAL
  status             String    @default("OPEN") // OPEN|UNDER_REVIEW|WON|LOST|CANCELLED
  evidenceDeadline   DateTime?
  adminNotes         String?
  outcome            String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

// ── Fraud Flags ───────────────────────────────────────────────────────────────

model FraudFlag {
  id          String    @id @default(cuid())
  type        String // VELOCITY|AMOUNT_THRESHOLD|CHARGEBACK_PATTERN|MANUAL
  severity    String    @default("MEDIUM") // LOW|MEDIUM|HIGH|CRITICAL
  status      String    @default("OPEN") // OPEN|REVIEWED|DISMISSED|ACTIONED
  description String
  orderId     String?
  userId      String?
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNote  String?
}
