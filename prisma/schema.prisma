// ── Creator Broadcasts ───────────────────────────────────────────────────────
// One-to-many announcements from creators to their followers. Distinct from
// Tickets (1-to-1, replies) and Posts (durable blog content). Retention is 30
// days hard delete; cap is 500 per-recipient FIFO. See plan file:
// docs/superpowers/plans/2026-04-24-in-app-broadcasts.md

enum BroadcastTemplate {
  NEW_DROP
  FLASH_SALE
  BEHIND_SCENES
  EVENT
  THANK_YOU
  MILESTONE
}

enum BroadcastAudience {
  ALL_FOLLOWERS
  SUBSCRIBERS_ONLY
}

model Broadcast {
  id        String            @id @default(cuid())
  creatorId String // → CreatorProfile.id (matches CreatorFollow.creatorId)
  title     String // max 60 chars, enforced app-side
  body      String // max 500 chars, enforced app-side
  imageKey  String? // R2 object key for hero image, null if no image
  ctaText   String? // max 30 chars
  ctaUrl    String? // validated to noizu.direct or allow-listed creator domain
  template  BroadcastTemplate
  audience  BroadcastAudience
  createdAt DateTime          @default(now())

  creator       CreatorProfile          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  notifications BroadcastNotification[]

  @@index([creatorId, createdAt])
  @@index([createdAt]) // retention sweep
}

model BroadcastNotification {
  id          String    @id @default(cuid())
  broadcastId String
  recipientId String // → User.id (buyer)
  readAt      DateTime?
  deletedAt   DateTime? // buyer hid their own copy — soft delete, per-user
  createdAt   DateTime  @default(now())

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  recipient User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, recipientId])
  @@index([recipientId, createdAt])
  @@index([recipientId, readAt])
}

