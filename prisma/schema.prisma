model PlatformSettings {
  id                             String  @id @default(cuid())
  processingFeePercent           Float   @default(2.5)
  platformFeePercent             Float   @default(0.0)
  withdrawalFeePercent           Float   @default(4.0)
  // ── Rail-aware fee model (sprint 0.1, 5/5.5/8 strategy) ──
  // creatorCommissionPercent: deducted from creator payout
  // buyerFeeLocalPercent:     surcharge added to buyer total on FPX/PayNow/etc
  // buyerFeeCardPercent:      surcharge added to buyer total on Visa/MC/AMEX
  creatorCommissionPercent       Float   @default(5.0)
  buyerFeeLocalPercent           Float   @default(5.5)
  buyerFeeCardPercent            Float   @default(8.0)
  topCreatorThreshold            Int     @default(100)
  // Escrow policy
  digitalEscrowHours             Int     @default(48)
  physicalEscrowDays             Int     @default(14)
  podEscrowDays                  Int     @default(30)
  commissionEscrowDays           Int     @default(30)
  newCreatorEscrowExtraDays      Int     @default(7)
  newCreatorTransactionThreshold Int     @default(10)
  // ── Clawback exposure window (sprint 1.1) ──
  // Earnings completed within the last N days are still chargeback-exposed and
  // shown as "Exposed" on creator dashboards (not yet eligible for payout).
  // Default 120d matches the longest standard card-network dispute window.
  clawbackExposureWindowDays     Int     @default(120)
  // ── Tax engine (sprint 2.1/2.2) ──
  // Per-country destination tax line is enabled when registration crosses the
  // country threshold. Stored as JSON: {"MY": true, "SG": false, ...}
  taxDestinationCountries        String  @default("{}")
  // Layer 1 personal-tax markup default for self-declared registered creators
  // (overridden per-creator via CreatorProfile.taxRatePercent if set).
  defaultCreatorTaxRatePercent   Float   @default(0.0)
  // ── Platform fee tax (2026-04-27, migration 0013) ──
  // Per-country admin-flipped config for taxing the platform's own commission
  // and/or buyer service fee. JSON: { [iso2]: { enabled, rate, label, sides: ('BUYER'|'CREATOR')[] } }
  // All countries default disabled at launch; admin enables per country once
  // platform crosses local registration threshold.
  platformFeeTax                 String  @default("{}")
  maintenanceMode                Boolean @default(false)
  maintenanceMessage             String?
}

